{
  "manifest_version": 3,
  "name": "YT Smart Chapters & Timestamps",
  "version": "1.7.0",
  "description": "Smart nearest jumps, auto-load chapters, draggable UI, native progress bar markers, and Turso DB integration.",
  "permissions": [
    "storage",
    "clipboardWrite"
  ],
  "host_permissions": [
    "*://*.youtube.com/*",
    "https://*.turso.io/*"
  ],
  "action": {
    "default_popup": "popup.html",
    "default_title": "YT Smart Chapters"
  },
  "content_scripts": [
    {
      "matches": ["*://*.youtube.com/*"],
      "css": ["styles.css"],
      "js": ["content.js"]
    }
  ],
  "background": {
    "service_worker": "background.js"
  }
}
