{
  "manifest_version": 3,
  "name": "YT Smart Chapters Pro v2.0",
  "version": "2.0.0",
  "description": "Smart jumps, mini-player widget, and custom shortcuts.",
  "permissions": [
    "storage",
    "clipboardWrite"
  ],
  "host_permissions": [
    "*://*.youtube.com/*",
    "https://*.turso.io/*"
  ],
  "action": {
    "default_title": "YT Smart Chapters Pro"
  },
  "content_scripts": [
    {
      "matches": ["*://*.youtube.com/*"],
      "css": ["content.css"],
      "js": ["content.js"]
    }
  ],
  "background": {
    "service_worker": "background.js"
  }
}
